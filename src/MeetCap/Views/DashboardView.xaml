<UserControl x:Class="MeetCap.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <FontFamily x:Key="Icons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

        <!-- Record / Stop button -->
        <Style x:Key="RecordButton" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FF2C7BE5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="25" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.78" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                    <Setter Property="Background" Value="#FFE23E48" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Icon-only secondary button -->
        <Style x:Key="IconTextButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,18,32,28">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,4,0,2" />
            <TextBlock Text="Record your meetings in one click." FontSize="13.5"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,20" />

            <!-- Hero status card -->
            <Border CornerRadius="18" Padding="28" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF222838" Offset="0" />
                                    <GradientStop Color="#FF1A1E2B" Offset="1" />
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                <Setter Property="BorderBrush" Value="#66E23E48" />
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF3A2230" Offset="0" />
                                            <GradientStop Color="#FF241A22" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- State indicator -->
                    <Grid Grid.Column="0" Width="56" Height="56" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#2238B36B" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Fill" Value="#33E23E48" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <Ellipse Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF38B36B" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Fill" Value="#FFE23E48" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.35" Duration="0:0:1.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusTitle}" FontSize="24" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{Binding StatusDetail}" FontSize="13.5" Margin="0,5,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Elapsed}" FontSize="34" FontFamily="Consolas"
                                   Margin="0,12,0,0" FontWeight="Medium"
                                   Foreground="#FFE23E48"
                                   Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>

                    <Button Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource RecordButton}"
                            Command="{Binding ToggleRecordingCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="14" Height="14" Fill="White" VerticalAlignment="Center"
                                     Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}" />
                            <Rectangle Width="13" Height="13" Fill="White" RadiusX="2" RadiusY="2" VerticalAlignment="Center"
                                       Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock Text="{Binding ToggleLabel}" Margin="11,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Info chips -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource InfoChip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE714;" FontFamily="{StaticResource Icons}" FontSize="20"
                                   VerticalAlignment="Center" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Quality" FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding QualityText}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource InfoChip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource Icons}" FontSize="20"
                                   VerticalAlignment="Center" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Save location" FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding FolderText}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource InfoChip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE82D;" FontFamily="{StaticResource Icons}" FontSize="20"
                                   VerticalAlignment="Center" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Library" FontSize="11.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding RecordingsCountText}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent recordings -->
            <Grid Margin="0,28,0,12">
                <TextBlock Text="Recent recordings" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource IconTextButton}" Margin="0,0,8,0" Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="{StaticResource Icons}" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="Refresh" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconTextButton}" Command="{Binding OpenFolderCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE838;" FontFamily="{StaticResource Icons}" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="Open folder" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Empty state -->
            <Border CornerRadius="14" Padding="36" Margin="0,4,0,0"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                    Visibility="{Binding HasRecordings, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE714;" FontFamily="{StaticResource Icons}" FontSize="32" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="No recordings yet" FontSize="15" FontWeight="SemiBold" Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Recordings will appear here after your first meeting." FontSize="13" Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding RecentRecordings}"
                          Visibility="{Binding HasRecordings, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Padding="14" Margin="0,0,0,10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" VerticalAlignment="Center"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="&#xE714;" FontFamily="{StaticResource Icons}" FontSize="20" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="14"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding CreatedDisplay}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="  ·  " FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconTextButton}" Margin="0,0,8,0"
                                            Command="{Binding DataContext.OpenRecordingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE768;" FontFamily="{StaticResource Icons}" FontSize="13" VerticalAlignment="Center" />
                                            <TextBlock Text="Play" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource IconTextButton}"
                                            Command="{Binding DataContext.RevealRecordingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Show in folder">
                                        <TextBlock Text="&#xE838;" FontFamily="{StaticResource Icons}" FontSize="14" VerticalAlignment="Center" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="MeetCap.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,16,28,24">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,4,0,18" />

            <!-- Status / control card -->
            <Border CornerRadius="14" Padding="24"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF38B36B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                <Setter Property="Fill" Value="#FFE83E48" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusTitle}" FontSize="22" FontWeight="SemiBold"
                                       Margin="12,0,0,0"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                        <TextBlock Text="{Binding StatusDetail}" FontSize="14" Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Elapsed}" FontSize="32" FontFamily="Consolas"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>

                    <ui:Button Grid.Column="1" VerticalAlignment="Center" MinWidth="170" Height="46"
                               FontSize="15"
                               Appearance="Primary"
                               Command="{Binding ToggleRecordingCommand}"
                               Content="{Binding ToggleLabel}" />
                </Grid>
            </Border>

            <!-- Recent recordings header -->
            <Grid Margin="0,26,0,10">
                <TextBlock Text="Recent recordings" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Refresh" Appearance="Secondary" Margin="0,0,8,0"
                               Command="{Binding RefreshCommand}" />
                    <ui:Button Content="Open folder" Appearance="Secondary"
                               Command="{Binding OpenFolderCommand}" />
                </StackPanel>
            </Grid>

            <!-- Empty state -->
            <Border CornerRadius="12" Padding="28" Margin="0,4,0,0"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="{Binding HasRecordings, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="No recordings yet" FontSize="15" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Your recordings will appear here once you record a meeting."
                               FontSize="13" Margin="0,6,0,0" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Recordings list -->
            <ItemsControl ItemsSource="{Binding RecentRecordings}"
                          Visibility="{Binding HasRecordings, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" Padding="16,12" Margin="0,0,0,8"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="14"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding CreatedDisplay}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text=" · " FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:Button Content="Play" Appearance="Secondary" Margin="0,0,8,0"
                                               Command="{Binding DataContext.OpenRecordingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}" />
                                    <ui:Button Content="Show in folder" Appearance="Secondary"
                                               Command="{Binding DataContext.RevealRecordingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<Window x:Class="MeetCap.Views.RecordingIndicatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Border CornerRadius="22" Padding="14,8" Background="#F01A1D27" BorderBrush="#33FFFFFF" BorderThickness="1"
            MouseLeftButtonDown="OnDragMove">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="Dot" Width="12" Height="12" Fill="#FFE83E48" VerticalAlignment="Center">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.25" Duration="0:0:0.9"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <TextBlock Text="REC" Foreground="White" FontWeight="Bold" FontSize="12.5"
                       Margin="9,0,0,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="ElapsedText" Text="00:00:00" Foreground="#DDFFFFFF" FontSize="12.5"
                       Margin="9,0,0,0" VerticalAlignment="Center" FontFamily="Consolas"/>
            <Button x:Name="StopButton" Content="Stop" Margin="12,0,0,0" Height="26" Padding="12,0"
                    Cursor="Hand" Foreground="White" BorderThickness="0" Click="OnStopClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="13" Background="#FFE83E48" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>

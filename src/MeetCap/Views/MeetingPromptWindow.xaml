<Window x:Class="MeetCap.Views.MeetingPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Width="380">
    <Border x:Name="RootBorder"
            CornerRadius="14"
            Margin="16"
            Padding="20"
            Background="#FF1E2230"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000" Direction="270"/>
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border Width="40" Height="40" CornerRadius="20" Background="#22E83E48" VerticalAlignment="Top">
                    <Ellipse Width="16" Height="16" Fill="#FFE83E48"/>
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Meeting detected"
                               Foreground="#FFFFFFFF" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="BrandText" Text="MeetCap"
                               Foreground="#99FFFFFF" FontSize="11" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBlock x:Name="MessageText"
                       Foreground="#DDFFFFFF" FontSize="13.5" TextWrapping="Wrap"
                       Margin="0,0,0,18" LineHeight="20"/>

            <StackPanel x:Name="ButtonPanel"/>
        </StackPanel>
    </Border>
</Window>

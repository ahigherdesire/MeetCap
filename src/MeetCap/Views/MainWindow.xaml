<ui:FluentWindow x:Class="MeetCap.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="MeetCap"
                 Width="980" Height="660"
                 MinWidth="820" MinHeight="540"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Icon="pack://application:,,,/Assets/meetcap.ico">

    <ui:FluentWindow.Resources>
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Margin" Value="10,2" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="8" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="MeetCap" Grid.ColumnSpan="2">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/meetcap.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation rail -->
            <Border Grid.Column="0" Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,18,0,18">
                        <Image Source="pack://application:,,,/Assets/meetcap.ico" Width="28" Height="28" />
                        <TextBlock Text="MeetCap" FontSize="18" FontWeight="Bold" Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     IsChecked="{Binding IsDashboardSelected, Mode=OneWay}"
                                     Command="{Binding ShowDashboardCommand}" Content="Dashboard" />
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     IsChecked="{Binding IsDashboardSelected, Converter={StaticResource InverseBoolConverter}, Mode=OneWay}"
                                     Command="{Binding ShowSettingsCommand}" Content="Settings" />
                    </StackPanel>

                    <!-- Recording status chip -->
                    <Border Grid.Row="2" Margin="12,0,12,16" CornerRadius="10" Padding="12,10"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="11" Height="11" Fill="#FFE83E48" VerticalAlignment="Center">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.3" Duration="0:0:0.9" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="Recording" Margin="9,0,0,0" VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{Binding Dashboard.Elapsed}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Page content -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="0" />
        </Grid>
    </Grid>
</ui:FluentWindow>

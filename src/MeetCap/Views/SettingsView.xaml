<UserControl x:Class="MeetCap.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,16,28,24">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="26" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,4,0,18" />

            <!-- Recording -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Recording" Style="{StaticResource SectionTitle}" />

                    <TextBlock Text="Save recordings to" Style="{StaticResource Label}" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Text="{Binding OutputFolder}" IsReadOnly="True" />
                        <ui:Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                                   Command="{Binding BrowseFolderCommand}" />
                    </Grid>

                    <TextBlock Text="Quality" Style="{StaticResource Label}" Margin="0,18,0,0" />
                    <ComboBox Margin="0,6,0,0" Width="260" HorizontalAlignment="Left"
                              ItemsSource="{Binding Qualities}" SelectedItem="{Binding Quality}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding QualityDescription}" Style="{StaticResource Hint}" />

                    <Grid Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Record system audio" Style="{StaticResource Label}" />
                            <TextBlock Text="Capture the meeting's sound (everyone you hear)." Style="{StaticResource Hint}" />
                        </StackPanel>
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding RecordSystemAudio}" />
                    </Grid>
                    <Grid Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Record microphone" Style="{StaticResource Label}" />
                            <TextBlock Text="Capture your own voice from the microphone." Style="{StaticResource Hint}" />
                        </StackPanel>
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding RecordMicrophone}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Startup & detection -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Startup &amp; detection" Style="{StaticResource SectionTitle}" />
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Start automatically on sign-in" Style="{StaticResource Label}" />
                            <TextBlock Text="MeetCap launches quietly to the tray when you log in." Style="{StaticResource Hint}" />
                        </StackPanel>
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding StartOnBoot}" />
                    </Grid>
                    <Grid Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Detect meetings automatically" Style="{StaticResource Label}" />
                            <TextBlock Text="Show a prompt when a meeting is detected." Style="{StaticResource Hint}" />
                        </StackPanel>
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding DetectionEnabled}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Platform detection -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Per-platform behavior" Style="{StaticResource SectionTitle}" />
                    <ItemsControl ItemsSource="{Binding Platforms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Label}" />
                                    <ComboBox HorizontalAlignment="Right" Width="220"
                                              ItemsSource="{Binding Actions}" SelectedItem="{Binding Action}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Privacy / consent -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Privacy &amp; consent" Style="{StaticResource SectionTitle}" />
                    <TextBlock Style="{StaticResource Hint}" FontSize="13"
                               Text="MeetCap never records without your action. Detection uses only safe local signals (running apps, window titles, and whether the microphone or camera is in use) — nothing is uploaded anywhere. Recording always begins from your explicit choice, and a visible indicator stays on screen the whole time. Always make sure the other participants are aware that the meeting is being recorded, as required by the laws in your area." />
                    <CheckBox Margin="0,14,0,0" IsChecked="{Binding ConsentAcknowledged}"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              Content="I understand and will obtain consent before recording." />
                </StackPanel>
            </Border>

            <TextBlock Margin="2,4,0,0" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <Run Text="MeetCap v" /><Run Text="{Binding AppVersion, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
